{
  "_description": "课程资料类型分类规则。每种类型定义检测特征、置信度加权、特殊标记和处理管线。",
  "types": {
    "textbook": {
      "name_zh": "教材",
      "name_en": "textbook",
      "priority": 1,
      "detection": {
        "filename_patterns": ["教材", "教科书", "课本", "textbook", "第.*章", "第.*讲", "chapter", "lecture"],
        "content_patterns": ["本章要点", "学习目标", "课后习题", "思考题", "本章小结", "CHAPTER", "Learning Objectives"],
        "structural_hints": ["层级标题深度 ≥3", "含目录结构", "段落编号如 §1.1 或 一、(一)、1."],
        "weight": 10
      },
      "affects_subject_confidence": 1.2,
      "output_pipeline": "standard",
      "frontmatter_type": "textbook",
      "tags": ["textbook", "教材"],
      "review_relevance": "high"
    },
    "lecture_notes": {
      "name_zh": "课程笔记",
      "name_en": "lecture_notes",
      "priority": 2,
      "detection": {
        "filename_patterns": ["笔记", "note", "整理", "课堂", "上课", "听课", "随堂"],
        "content_patterns": ["老师", "教授", "上课", "课堂", "板书", "PPT", "课件", "补充", "→", "=>", "ps:", "注:", "重点标记"],
        "structural_hints": ["非正式编号", "缩进层次不均", "含个人注释/批注", "有日期头", "含手写风格标记"],
        "weight": 9
      },
      "affects_subject_confidence": 1.0,
      "output_pipeline": "standard",
      "frontmatter_type": "course-note",
      "tags": ["course-note", "笔记"],
      "review_relevance": "high"
    },
    "key_points": {
      "name_zh": "重点/考点",
      "name_en": "key_points",
      "priority": 1,
      "detection": {
        "filename_patterns": ["重点", "考点", "必考", "冲刺", "精华", "干货", "总结", "提要", "大纲", "考纲", "范围", "题型"],
        "content_patterns": ["【★", "【必考】", "【重点】", "【历年真题】", "★★★", "⚠", "❗", "高频", "常考", "不考", "了解即可", "重点掌握", "必须记住", "核心概念"],
        "structural_hints": ["密集的加粗/高亮", "列表项含★或数字序号", "含'不考'排除标记"],
        "weight": 12
      },
      "affects_subject_confidence": 1.5,
      "output_pipeline": "key_points_extraction",
      "frontmatter_type": "exam-key-points",
      "tags": ["exam-prep", "重点", "考点"],
      "review_relevance": "highest",
      "special_handling": "标记为【★重点】体系的一部分，导入后自动关联到 topic_map"
    },
    "past_exams": {
      "name_zh": "往年题",
      "name_en": "past_exams",
      "priority": 1,
      "detection": {
        "filename_patterns": ["真题", "往年", "期末", "考试", "试卷", "试题", "exam", "考题", "历年", "回忆版", "样题", "模拟"],
        "content_patterns": ["一、", "二、", "三、", "简答题", "论述题", "案例分析题", "名词解释", "选择题", "判断题", "填空题", "参考答案", "评分标准", "答题要点", "（.*分）", "总分"],
        "structural_hints": ["Q&A交替结构", "题号+分值标注", "含答题纸/答题区域"],
        "weight": 11
      },
      "affects_subject_confidence": 1.3,
      "output_pipeline": "exam_extraction",
      "frontmatter_type": "past-exam",
      "tags": ["exam-prep", "往年题"],
      "review_relevance": "highest",
      "special_handling": "按题型拆分为独立块，标注年份+分值，自动生成考点权重统计"
    },
    "case_materials": {
      "name_zh": "案例材料",
      "name_en": "case_materials",
      "priority": 2,
      "detection": {
        "filename_patterns": ["案例", "判决", "裁判", "case", "判例", "裁定", "实例", "案情"],
        "content_patterns": ["原告", "被告", "公诉", "辩护", "法院认为", "判决如下", "裁定", "案情", "争议焦点", "本院认为", "原审", "上诉", "v\\.", "plaintiff", "defendant", "held that"],
        "structural_hints": ["含当事人信息", "含案号", "含法院名称", "事实+理由+判决三段式"],
        "weight": 8
      },
      "affects_subject_confidence": 1.1,
      "output_pipeline": "case_extraction",
      "frontmatter_type": "case-material",
      "tags": ["case", "案例"],
      "review_relevance": "high",
      "special_handling": "六段式结构化提取：案情事实→当事人诉求/辩护→争议焦点归纳→裁判结果→关键论证→确立原则/后续影响。按章节知识点匹配归属：章节内引用→嵌入该章节；单独文件且单章节→嵌入；单独文件跨多章节且后文章节为核心→放笔记最后（综合性案例）。案例后附Q&A→逐题解答分析。",
      "case_structure_template": {
        "facts": "案情事实：客观案情经过",
        "claims_defenses": "当事人诉求/辩护：原告主张 / 被告抗辩",
        "disputed_issues": "争议焦点归纳：法院提炼的法律问题",
        "judgment": "裁判结果：判决/裁定结论",
        "key_reasoning": "关键论证：法院的推理链条",
        "principle_impact": "确立原则/后续影响：判例确立的法律规则 / 对后续案件的影响"
      },
      "case_placement_rules": {
        "embedded_in_chapter": "案例在笔记/课件某个章节内被引用 → 嵌入该章节复习稿",
        "standalone_single_chapter": "单独文件，仅涉及单一章节 → 嵌入对应章节",
        "standalone_cross_chapter_non_core": "涉及多章节但后文章节非核心 → 嵌入主要涉及章节",
        "standalone_cross_chapter_core": "涉及多章节且后文章节为核心 → 放笔记最后作为综合性案例",
        "with_qa": "案例后附Q&A问题 → 基于案例内容逐题解答分析（案情仍六段式提供）",
        "judgment_criteria": "判断依据：案例在笔记/课件中是章节内引用，还是独立综合案例文件"
      }
    },
    "glossary": {
      "name_zh": "缩略术语表",
      "name_en": "glossary",
      "priority": 3,
      "detection": {
        "filename_patterns": ["术语", "名词解释", "概念", "glossary", "定义", "缩写", "缩略", "词汇", "词典"],
        "content_patterns": ["：", "——", "是指", "指的是", "又称", "简称", "即", "definition", "refers to", "缩写", "全称"],
        "structural_hints": ["术语-定义对", "表格形式（术语|定义）", "字母序排列", "每行一个概念"],
        "weight": 7
      },
      "affects_subject_confidence": 1.0,
      "output_pipeline": "glossary_extraction",
      "frontmatter_type": "glossary",
      "tags": ["glossary", "术语"],
      "review_relevance": "medium",
      "special_handling": "提取为术语卡片格式，链接到概念与原则目录"
    },
    "reading_materials": {
      "name_zh": "阅读材料",
      "name_en": "reading_materials",
      "priority": 3,
      "detection": {
        "filename_patterns": ["阅读", "文献", "reading", "参考文献", "推荐阅读", "拓展", "补充阅读", "必读"],
        "content_patterns": ["参考文献", "引用", "参见", "出处", "citation", "reference", "bibliography", "et al", "ibid"],
        "structural_hints": ["含文献列表", "含脚注/尾注", "学术写作格式"],
        "weight": 6
      },
      "affects_subject_confidence": 0.9,
      "output_pipeline": "reading_list_extraction",
      "frontmatter_type": "reading-material",
      "tags": ["reading", "文献"],
      "review_relevance": "medium",
      "special_handling": "如果含章节对应标记，按章节拆分为 MOC 子条目；否则作为学科阅读索引追加"
    },
    "academic_paper": {
      "name_zh": "学术论文",
      "name_en": "academic_paper",
      "priority": 3,
      "detection": {
        "filename_patterns": ["论文", "paper", "article", "学位", "毕业论文", "开题", "研究"],
        "content_patterns": ["摘要", "关键词", "abstract", "keywords", "引言", "introduction", "结论", "conclusion", "方法论", "methodology", "文献综述", "literature review", "致谢", "acknowledgment"],
        "structural_hints": ["含摘要+关键词块", "IMRaD结构", "含DOI/刊名/卷期"],
        "weight": 5
      },
      "affects_subject_confidence": 0.8,
      "output_pipeline": "paper_extraction",
      "frontmatter_type": "academic-paper",
      "tags": ["paper", "论文", "学术"],
      "review_relevance": "low",
      "special_handling": "提取摘要+核心论点+方法论，按主题关联到对应课程 MOC"
    },
    "syllabus": {
      "name_zh": "考纲/教学大纲",
      "name_en": "syllabus",
      "priority": 1,
      "detection": {
        "filename_patterns": ["考纲", "大纲", "教学计划", "syllabus", "课程简介", "课程说明", "考核方式"],
        "content_patterns": ["课程目标", "教学内容", "学时", "学分", "考核", "成绩构成", "平时成绩", "期末成绩", "先修课程", "教材", "参考书"],
        "structural_hints": ["含学时分配表", "含成绩比例", "含章节列表+学时"],
        "weight": 11
      },
      "affects_subject_confidence": 1.4,
      "output_pipeline": "syllabus_extraction",
      "frontmatter_type": "syllabus",
      "tags": ["syllabus", "考纲", "exam-prep"],
      "review_relevance": "highest",
      "special_handling": "最高优先级：提取考点权重分配，直接作为 topic_map.json 骨架"
    }
  },

  "type_priority_for_conflict": [
    "syllabus",
    "key_points",
    "past_exams",
    "textbook",
    "case_materials",
    "lecture_notes",
    "glossary",
    "reading_materials",
    "academic_paper"
  ],

  "bilingual_annotation_rules": {
    "_description": "双语标注策略。根据 language_mode 决定什么需要标注、标注到什么程度。",
    "mode_1_zh_dominant_en_annotation": {
      "name": "中文主体 + 英文关键表达标注",
      "target_user": "英语阅读慢、中文理解快、但必须应考英文的学生",
      "body_language": "zh",
      "annotate": {
        "abbreviations": {"rule": "首次出现的英文缩写 → 标注全称+中文", "example": "CISG (United Nations Convention on Contracts for the International Sale of Goods, 联合国国际货物销售合同公约)"},
        "key_terms": {"rule": "决定答题得分的术语 → 括号标注英文", "example": "对价 (consideration)、允诺禁反言 (promissory estoppel)"},
        "key_phrases": {"rule": "考试中必须准确使用的短语 → 标注英文", "example": "注意义务 (duty of care)、举证责任 (burden of proof)"},
        "key_sentences": {"rule": "判例法标准表述/法条原文关键句 → 双语引用", "example": "*The neighbor principle: You must take reasonable care...* (邻人原则：你必须采取合理注意……)"}
      },
      "annotation_strategy": "分层标注：首次出现完整标注（中文+英文），后续出现可仅保留英文关键词"
    },
    "mode_2_en_dominant_zh_annotation": {
      "name": "英文主体 + 中文难词标注",
      "target_user": "英语好、用英文复习、遇到超纲词汇需要中文辅助的学生",
      "body_language": "en",
      "annotate": {
        "latin_french_terms": {"rule": "拉丁文/法语法律专有名词 → 括号标注中文", "example": "*force majeure* (不可抗力), *res judicata* (既判力)"},
        "difficult_terms": {"rule": "超出日常词汇量的学术/法律术语 → 标注中文", "example": "promulgate (颁布), encumbrance (权利负担)"},
        "non_intuitive_phrases": {"rule": "英文中不直观的专业表达 → 标注中文", "example": "*ratio decidendi* (判决理由), *obiter dicta* (附带意见)"}
      },
      "annotation_strategy": "仅标注难词生词专有名词，常见法律术语不标注（如 contract, negligence 等基础词汇不需要中文）"
    },
    "mode_3_zh_only": {"name": "纯中文", "rule": "仅保留中文。英文术语如原文仅有英文则保留原文。"},
    "mode_4_en_only": {"name": "纯英文", "rule": "仅保留英文。中文术语如原文仅有中文则保留原文。"}
  },

  "type_detection_thresholds": {
    "high_confidence": 8,
    "medium_confidence": 5,
    "low_confidence": 3
  },

  "special_markers": {
    "exam_critical": ["【★重点】", "【必考】", "【历年真题】", "【高频】"],
    "exam_excluded": ["【不考】", "【了解即可】", "【略】"],
    "quality_flags": ["【待核实】", "【存疑】", "【缺】", "【待补充】"]
  }
}
