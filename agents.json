{
  "_description": "Multi-agent skill deployment config. Each entry defines where this agent expects skill files. install.py reads this to create the appropriate symlinks/copies.",
  "_note": "Paths with ~ or %VAR% are expanded at runtime. {skill_name} is replaced with 'final-review'.",

  "agents": {
    "claude-code": {
      "name": "Claude Code (CLI)",
      "type": "skill_md",
      "paths": {
        "windows": "~/.claude/skills/{skill_name}/",
        "macos": "~/.claude/skills/{skill_name}/",
        "linux": "~/.claude/skills/{skill_name}/"
      },
      "files": {
        "SKILL.md": "SKILL.md"
      },
      "checks": [".claude/", "~/.claude/skills/"]
    },

    "claude-code-ide": {
      "name": "Claude Code (VS Code / JetBrains)",
      "type": "skill_md",
      "paths": {
        "windows": "%USERPROFILE%/.claude/skills/{skill_name}/",
        "macos": "~/.claude/skills/{skill_name}/",
        "linux": "~/.claude/skills/{skill_name}/"
      },
      "files": {
        "SKILL.md": "SKILL.md"
      },
      "checks": [".claude/skills/"]
    },

